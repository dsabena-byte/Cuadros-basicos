# JSON entero de la service account de Google Cloud (lectura sobre Drive).
# Pegá el contenido del archivo .json de credenciales en una sola linea.
GOOGLE_SERVICE_ACCOUNT_JSON=

# ID de la carpeta de Drive donde se suben los CSV semanales.
DRIVE_FOLDER_ID=1J7NORR3iwnjbKrIAbjB79N7h5klGFYR3

# Secreto compartido con Apps Script para el webhook /api/refresh.
REFRESH_SECRET=

# Tiempo de cache del dashboard en segundos (ISR fallback).
DASHBOARD_REVALIDATE_SECONDS=3600
